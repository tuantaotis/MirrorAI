# MirrorAI Environment Variables
# Copy this to .env and fill in your values

# ── Telegram ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
# TELEGRAM_API_ID=         # Optional: for user account access
# TELEGRAM_API_HASH=       # Optional: for user account access

# ── Zalo ─────────────────────────────────────
ZALO_BOT_TOKEN=
# Zalo Personal: no token needed, uses QR login

# ── AI Providers (Optional - for cloud fallback) ──
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ── Ollama ───────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── ChromaDB ─────────────────────────────────
CHROMADB_URL=http://localhost:8000

# ── OpenClaw ─────────────────────────────────
# OPENCLAW_GATEWAY_TOKEN=  # Optional: gateway auth token

# ── Logging ──────────────────────────────────
LOG_LEVEL=info
