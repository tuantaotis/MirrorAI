{
  "id": "mirrorai",
  "name": "MirrorAI",
  "version": "1.0.0",
  "description": "AI Clone — mirror your persona across chat platforms. Learns your writing style from chat history and responds as you.",
  "author": "MirrorAI Team",
  "license": "MIT",
  "repository": "https://github.com/mirrorai/mirrorai",
  "homepage": "https://github.com/mirrorai/mirrorai",
  "keywords": ["ai-clone", "persona", "rag", "chatbot", "telegram", "zalo"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "chromadb_url": {
        "type": "string",
        "default": "http://localhost:8000",
        "description": "ChromaDB server URL"
      },
      "persona_confidence_threshold": {
        "type": "number",
        "default": 0.65,
        "minimum": 0,
        "maximum": 1,
        "description": "Minimum confidence to auto-reply (0.0 - 1.0)"
      },
      "max_rag_results": {
        "type": "integer",
        "default": 5,
        "description": "Number of similar messages to retrieve"
      },
      "auto_reply": {
        "type": "boolean",
        "default": true,
        "description": "Enable automatic replies"
      },
      "manual_review_queue": {
        "type": "boolean",
        "default": true,
        "description": "Queue low-confidence messages for manual review"
      },
      "response_delay_min_ms": {
        "type": "integer",
        "default": 800,
        "description": "Minimum response delay (ms) for human-like timing"
      },
      "response_delay_max_ms": {
        "type": "integer",
        "default": 8000,
        "description": "Maximum response delay (ms)"
      },
      "model": {
        "type": "string",
        "default": "ollama/qwen2.5:14b",
        "description": "AI model for response generation"
      }
    }
  },
  "skills": [
    "skills/mirror-respond.ts",
    "skills/data-ingest.ts",
    "skills/persona-update.ts",
    "skills/persona-status.ts",
    "skills/export-telegram.ts",
    "skills/export-zalo.ts",
    "skills/export-facebook.ts",
    "skills/export-instagram.ts",
    "skills/export-discord.ts",
    "skills/export-whatsapp.ts"
  ],
  "channels": ["telegram", "zalo", "zalouser", "facebook", "instagram", "discord", "whatsapp"],
  "platforms": {
    "telegram": { "skill": "export-telegram", "status": "ready" },
    "zalo": { "skill": "export-zalo", "status": "ready" },
    "facebook": { "skill": "export-facebook", "status": "manual" },
    "instagram": { "skill": "export-instagram", "status": "manual" },
    "discord": { "skill": "export-discord", "status": "manual" },
    "whatsapp": { "skill": "export-whatsapp", "status": "manual" }
  },
  "requires": {
    "runtime": ["python3", "node"],
    "services": ["chromadb", "ollama"]
  }
}
